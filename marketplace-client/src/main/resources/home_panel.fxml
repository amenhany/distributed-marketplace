<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" xmlns:fx="http://javafx.com/fxml" 
      fx:controller="org.team13.marketplace.client.controllers.HomeController"
      style="-fx-padding: 20; -fx-background-color: #f5f5f5;">
    
    <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 10; -fx-background-color: white; -fx-background-radius: 5;">
        <Label text="Marketplace Home" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Account Info" onAction="#handleAccountInfo" style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
        <Button text="Logout" onAction="#handleLogout" style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
    </HBox>
    
    <VBox spacing="10" style="-fx-padding: 15; -fx-background-color: white; -fx-background-radius: 5;">
        <Label text="Search Items" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
        <HBox spacing="10">
            <TextField fx:id="searchField" promptText="Search by name or brand" HBox.hgrow="ALWAYS"/>
            <Button text="Search" onAction="#handleSearch" style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
        </HBox>
    </VBox>
    
    <TableView fx:id="itemsTable" VBox.vgrow="ALWAYS" style="-fx-background-color: white;">
        <columns>
            <TableColumn fx:id="nameColumn" text="Name" prefWidth="150"/>
            <TableColumn fx:id="brandColumn" text="Brand" prefWidth="120"/>
            <TableColumn fx:id="priceColumn" text="Price" prefWidth="100"/>
            <TableColumn fx:id="sellerColumn" text="Seller" prefWidth="120"/>
            <TableColumn fx:id="actionColumn" text="Action" prefWidth="100"/>
        </columns>
    </TableView>
    
</VBox>
